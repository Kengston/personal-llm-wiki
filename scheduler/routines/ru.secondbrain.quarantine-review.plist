<?xml version="1.0" encoding="UTF-8"?>
<!--
  ru.secondbrain.quarantine-review.plist — LaunchAgent routine QUARANTINE-REVIEW
  (мандатное/SLA'd ревью карантина фильтра контента, ADR-0011 §8b/§11).

  ШАБЛОН: замени __PUBLIC_REPO__ на абсолютный путь к репо personal-llm-wiki ПЕРЕД
  установкой. Установка/снятие — см. scheduler/README.md и setup/SETUP.md.

  ЧТО ДЕЛАЕТ: периодически (routine #6 каталога) READ-ONLY читает ledger
  raw/.filter-log.jsonl, агрегирует карантин по категориям и формирует владельцу
  ОЧЕРЕДЬ НА РЕВЬЮ — «N в карантине, проверить? одобрить re-promote / оставить».
  Сурфейсит ТОЛЬКО метаданные/лог (путь, категория, score, sha256, одна sanitized-
  строка) — НИКОГДА тела карантина (P0-2, изоляция инъекций: карантинный документ
  мог прийти из недоверенного источника / содержать prompt-injection).

  ПОЧЕМУ ОТДЕЛЬНАЯ ОТ digest: digest даёт лёгкий БАТЧ-нудж «N за период — проверить?»
  каждое утро; этот routine — МАНДАТНЫЙ периодический проход с SLA (карантин не
  должен копиться молча) + механизм ОДНОШАГОВОГО логируемого re-promote ложных
  срабатываний (escape-hatch, ADR-0011: карантин предпочитает ложно-положительные,
  поэтому дешёвый возврат обязателен). re-promote — это НЕ хард-удаление: raw/
  иммутабелен, «вернуть» = пометить документ к промоушену + строка в ledger/log.md.

  ПОЧЕМУ launchd-LaunchAgent (не Daemon): GUI-юзер → сеть + `claude login`-сессия
  (ADR-0008/0009), sudo не нужен. 24/7-альтернатива — remote Claude routine (README.md).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ru.secondbrain.quarantine-review</string>

    <!-- Generic-обёртка с именем routine первым аргументом (как остальные). -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PUBLIC_REPO__/scheduler/run_routine.sh</string>
        <string>quarantine-review</string>
    </array>

    <!-- МАНДАТНОЕ ревью с SLA: дважды в неделю (Weekday 1=Пн и 4=Чт) в 09:30,
         чтобы карантин не залёживался дольше ~3–4 дней. StartCalendarInterval
         принимает массив словарей — несколько слотов. Правь частоту под свой SLA. -->
    <key>StartCalendarInterval</key>
    <array>
        <dict>
            <key>Weekday</key>
            <integer>1</integer>
            <key>Hour</key>
            <integer>9</integer>
            <key>Minute</key>
            <integer>30</integer>
        </dict>
        <dict>
            <key>Weekday</key>
            <integer>4</integer>
            <key>Hour</key>
            <integer>9</integer>
            <key>Minute</key>
            <integer>30</integer>
        </dict>
    </array>

    <key>RunAtLoad</key>
    <false/>
    <key>KeepAlive</key>
    <false/>

    <key>WorkingDirectory</key>
    <string>__PUBLIC_REPO__</string>

    <key>StandardOutPath</key>
    <string>__PUBLIC_REPO__/scheduler/quarantine-review.out.log</string>
    <key>StandardErrorPath</key>
    <string>__PUBLIC_REPO__/scheduler/quarantine-review.err.log</string>

    <!-- CONTENT_ROOT/секреты подтянет run_routine.sh из приватного .env; здесь только PATH. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
    </dict>

    <!-- Ревью — лёгкое (только ledger-метаданные + короткий push); 5 мин с запасом. -->
    <key>ExitTimeOut</key>
    <integer>300</integer>

    <key>ProcessType</key>
    <string>Background</string>
    <key>Nice</key>
    <integer>5</integer>
</dict>
</plist>
