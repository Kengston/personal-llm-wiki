# ---------------------------------------------------------------------------
# .env.example — шаблон окружения «Второго мозга» (TypeScript-порт, [ADR-0012]).
#
# Скопируй в .env (КОРЕНЬ публичного репо) и заполни РЕАЛЬНЫМИ значениями. Мост
# (dist/bridge/main.js) грузит .env отсюда через dotenv-flow. Файл .env держим
# ТОЛЬКО локально (gitignored), реальные токены НИКОГДА не коммитим — это публичный
# фреймворк-репо ([ADR-0003]). Значения ниже — заведомо ФЕЙКОВЫЕ плейсхолдеры.
#
# Где брать значения — см. setup/SETUP.md. Сборка перед запуском: pnpm install && pnpm build.
# ---------------------------------------------------------------------------

# --- Telegram Bot API -------------------------------------------------------
# Токен бота от @BotFather. Формат "<bot_id>:<секрет>". (плейсхолдер — фейк)
TELEGRAM_BOT_TOKEN=123456789:AA-FAKE-EXAMPLE-TOKEN-DO-NOT-USE

# id чата владельца — ЕДИНСТВЕННЫЙ разрешённый чат (hard allow-list, слой №2,
# single-user-инвариант [ADR-0009]). Узнаётся через @userinfobot. (плейсхолдер)
TELEGRAM_OWNER_CHAT_ID=111111111

# Секрет webhook'а. И как secret-token-заголовок (слой №1), И как nonce пути (слой №3).
# Только [A-Za-z0-9_-], 1..256 символов. Сгенерировать:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
TELEGRAM_WEBHOOK_SECRET=replace_me_with_a_long_random_urlsafe_secret

# --- Движок (выбор адаптера) ------------------------------------------------
# Какой адаптер Engine поднимать: claude (дефолт v1, ToS-safe) | grok | codex (ОТЛОЖЕНЫ).
ENGINE=claude

# Рабочая директория движка = ПРИВАТНЫЙ контент-репо (raw/ + wiki/ + reminders/).
# Абсолютный путь к llm-wiki-content. ОБЯЗАТЕЛЬНО для любого движка.
WIKI_REPO_PATH=/Users/example/llm-wiki-content

# Жёсткий timeout одного хода движка, секунды.
ENGINE_TIMEOUT_SEC=180

# --- Движок: Claude (дефолт, официальный бинарь) ----------------------------
# ⚠ ToS-safe ([ADR-0009]): мост зовёт только официальный бинарь `claude` под
# аккаунтом владельца. НИКОГДА не реюзать OAuth-токен в стороннем клиенте.
CLAUDE_BIN=claude
# CLAUDE_MODEL=
# CLAUDE_CONTINUE_LATEST=0

# --- Движок: Grok / Codex (ОТЛОЖЕНЫ — [ADR-0008]) ---------------------------
# GROK_BACKEND=grok-build-cli   # или openclaw (допустим ТОЛЬКО для Grok, [ADR-0009])
# GROK_BIN=grok
# OPENCLAW_BIN=openclaw
# CODEX_BIN=codex

# --- Мост -------------------------------------------------------------------
# Путь к SQLite-файлу карты chat_id->session_id (node:sqlite).
BRIDGE_DB_PATH=/Users/example/llm-wiki-content/.bridge/chat_sessions.sqlite
# Размер буфера входящих сообщений и число воркеров.
BRIDGE_QUEUE_SIZE=100
BRIDGE_WORKERS=1
# Порт, на котором слушает Fastify-мост (за ним Cloudflare Tunnel).
BRIDGE_PORT=8080
# Логи: 1 → JSON (pino), 0 → человекочитаемый pino-pretty.
LOG_JSON=1

# --- Плановое (scheduler) + ингест ------------------------------------------
# Обычно эти переменные задаёт ПРИВАТНЫЙ .env ($CONTENT_ROOT/.env), который грузят
# run_sweep.sh / run_routine.sh. Здесь — для справки/локального запуска.
# CONTENT_ROOT=/Users/example/llm-wiki-content
# REMINDERS_PATH, WIKI_DIR, RAW_DIR, FILTER_LOG, TASKS_INBOX — авто от CONTENT_ROOT.
# DIGEST_LOOKAHEAD_DAYS=7
# DIGEST_GRACE_MINUTES=5
# Каталог raw/ для коннекторов ingest (llm-chat / telegram-export):
# LLM_WIKI_RAW_DIR=/Users/example/llm-wiki-content/raw
