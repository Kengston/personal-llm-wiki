# ---------------------------------------------------------------------------
# bridge/.env.example — шаблон окружения моста Telegram <-> движок (дефолт Claude).
#
# Скопируй в .env и заполни РЕАЛЬНЫМИ значениями. Файл .env держим ТОЛЬКО локально
# (gitignored), реальные токены НИКОГДА не коммитим — это публичный фреймворк-репо
# ([ADR-0003]). Значения ниже — заведомо ФЕЙКОВЫЕ плейсхолдеры для примера.
#
# Где брать значения — см. setup/SETUP.md.
# ---------------------------------------------------------------------------

# --- Telegram Bot API -------------------------------------------------------
# Токен бота от @BotFather. Формат: "<bot_id>:<секрет>". (плейсхолдер — фейк)
TELEGRAM_BOT_TOKEN=123456789:AA-FAKE-EXAMPLE-TOKEN-DO-NOT-USE

# id чата владельца — ЕДИНСТВЕННЫЙ разрешённый чат (hard allow-list, слой №2,
# single-user-инвариант [ADR-0009]). Узнаётся один раз: послать боту /start и
# прочитать chat.id из getUpdates (инструкция в setup/SETUP.md). Для 1:1-чата
# chat_id == user_id. (плейсхолдер)
TELEGRAM_OWNER_CHAT_ID=111111111

# Секрет webhook'а. Используется И как secret-token-заголовок Telegram (слой №1),
# И как nonce в пути URL (слой №3). Допустимы только [A-Za-z0-9_-], 1..256 символов
# (ограничение Telegram secret_token). Сгенерировать высокоэнтропийный:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Затем тем же значением вызвать setWebhook (см. SETUP.md). (плейсхолдер — фейк)
TELEGRAM_WEBHOOK_SECRET=replace_me_with_a_long_random_urlsafe_secret

# --- Движок (выбор адаптера) ------------------------------------------------
# Какой адаптер Engine поднимать. По умолчанию "claude" (дефолт v1, ToS-safe).
# Допустимо: claude (дефолт) | grok (ОТЛОЖЕН) | codex (ОТЛОЖЕН). См. [ADR-0008].
ENGINE=claude

# Рабочая директория движка = ПРИВАТНЫЙ контент-репо (raw/ + wiki/ + reminders/).
# Абсолютный путь к llm-wiki-content на этой машине. ОБЯЗАТЕЛЬНО для любого движка.
WIKI_REPO_PATH=/Users/example/llm-wiki-content

# Жёсткий timeout одного хода движка, секунды (по истечении процесс убивается).
ENGINE_TIMEOUT_SEC=180

# --- Движок: Claude (дефолт, официальный бинарь) ----------------------------
# Путь/имя ОФИЦИАЛЬНОГО бинаря Claude Code. По умолчанию ищется в PATH.
# ⚠ ToS-safe ([ADR-0009]): мост зовёт только этот официальный бинарь под аккаунтом
# владельца. НИКОГДА не реюзать OAuth-токен Claude в стороннем HTTP-клиенте.
CLAUDE_BIN=claude

# Запиненная модель Claude (опц.). Пусто → дефолт Claude Code.
# CLAUDE_MODEL=

# Resume по chat: 0 → адресовать сессию явно (`--resume <id>`, рекомендуется);
# 1 → использовать `--continue` (самый свежий диалог в cwd).
# CLAUDE_CONTINUE_LATEST=0

# --- Движок: Grok (ОТЛОЖЕН — advisor-голос, [ADR-0008]) ---------------------
# Включается ENGINE=grok. Бэкенд: "grok-build-cli" (официальный) или "openclaw".
# ⚠ OpenClaw допустим ТОЛЬКО для Grok (санкционирован xAI); на Claude он ЗАПРЕЩЁН
# ([ADR-0009]). Раскомментируй при подключении Grok.
# GROK_BACKEND=grok-build-cli
# GROK_BIN=grok
# OPENCLAW_BIN=openclaw
# GROK_MODEL=

# --- Движок: Codex (ОТЛОЖЕН — нет ChatGPT-подписки, [ADR-0008]) -------------
# Включается ENGINE=codex. Слот портируемости (supersedes [ADR-0001]).
# CODEX_BIN=codex
# CODEX_MODEL=

# --- Мост -------------------------------------------------------------------
# Путь к SQLite-файлу карты chat_id->session_id.
BRIDGE_DB_PATH=/Users/example/llm-wiki-content/.bridge/chat_sessions.sqlite

# Размер буфера входящих сообщений (asyncio.Queue).
BRIDGE_QUEUE_SIZE=100

# Число воркеров очереди (для личного бота 1-2 достаточно).
BRIDGE_WORKERS=1

# Порт, на котором слушает uvicorn (за ним стоит Cloudflare Tunnel).
BRIDGE_PORT=8080

# Логи в JSON (1) или человекочитаемой консолью (0).
LOG_JSON=1
